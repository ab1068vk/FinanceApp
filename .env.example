# Generate with: openssl rand -hex 32
JWT_SECRET=replace-with-at-least-32-bytes-of-random-secret
DB_PATH=./backend/database/financeapp.db
PORT=3000
TRUST_PROXY_HOPS=1
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD_HASH=replace-with-password-hash

# Email delivery for verification and password reset links.
# Use an app password or provider SMTP token, never your normal mailbox password.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_REQUIRE_TLS=true
SMTP_TLS_REJECT_UNAUTHORIZED=true
SMTP_USER=mailer@example.com
SMTP_PASS=replace-with-provider-app-password
EMAIL_FROM="FinanceApp <mailer@example.com>"
MOBILE_APP_ORIGIN=http://localhost:19006
APP_WEB_FALLBACK_URL=http://localhost:19006
PASSWORD_RESET_URL=financeapp://reset-password?token={token}
EMAIL_VERIFICATION_URL=financeapp://verify-email?token={token}
MIN_APP_VERSION=1.0.0
BACKUP_HOUR=3
BACKUP_DIR=./backups
BACKUP_RETAIN_DAYS=7

# Mobile .env / Expo public vars
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000
EXPO_PUBLIC_APP_STORE_URL=https://apps.apple.com/app/financeapp
EXPO_PUBLIC_PLAY_STORE_URL=https://play.google.com/store/apps/details?id=com.financeapp.mobile
EXPO_PUBLIC_API_CERT_HASH=sha256/replace-with-pinned-cert-hash
